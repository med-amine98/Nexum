@router.post("/thresholds")
async def create_threshold(
    data: Dict[str, Any],
    current_user = Depends(get_current_user),
    db: Session = Depends(get_db)
):
    """Crée un seuil d'alerte"""
    try:
        from app.models.predictive_analytics import AlertThreshold, MetricType, AlertLevel
        
        threshold = AlertThreshold(
            metric=MetricType(data["metric"]),
            condition=data["condition"],
            threshold=data["threshold"],
            level=AlertLevel(data.get("level", "warning")),
            notification_method=data.get("notification_method", ["email"]),
            is_active=data.get("is_active", True)
        )
        db.add(threshold)
        db.commit()
        db.refresh(threshold)
        
        logger.info(f"✅ Seuil d'alerte créé: {threshold.metric.value} {threshold.condition} {threshold.threshold}")
        return {"success": True, "id": threshold.id}
    except Exception as e:
        db.rollback()
        logger.error(f"Erreur create threshold: {e}")
        raise HTTPException(status_code=500, detail=str(e))


@router.post("/historical-data")
async def add_historical_data(
    data: Dict[str, Any],
    current_user = Depends(get_current_user),
    db: Session = Depends(get_db)
):
    """Ajoute des données historiques manuellement"""
    try:
        from app.models.predictive_analytics import HistoricalData, MetricType
        
        historical = HistoricalData(
            date=datetime.fromisoformat(data["date"]),
            metric=MetricType(data["metric"]),
            value=data["value"],
            notes=data.get("notes", "")
        )
        db.add(historical)
        db.commit()
        db.refresh(historical)
        
        logger.info(f"✅ Donnée historique ajoutée: {historical.metric.value} = {historical.value}")
        return {"success": True, "id": historical.id}
    except Exception as e:
        db.rollback()
        logger.error(f"Erreur add historical: {e}")
        raise HTTPException(status_code=500, detail=str(e))


@router.post("/simulate")
async def run_simulation(
    data: Dict[str, Any],
    db: Session = Depends(get_db)
):
    """Exécute une simulation de scénario B2B"""
    try:
        # Vérifier que le scénario existe
        from app.models.predictive_analytics import SimulationScenario
        
        scenario_id = data.get("scenario_id")
        if scenario_id:
            scenario = db.query(SimulationScenario).filter(
                SimulationScenario.id == scenario_id
            ).first()
            if not scenario:
                raise HTTPException(status_code=404, detail="Scénario non trouvé")
        
        result = predictive_service.run_simulation(
            db, 
            scenario_id, 
            data.get("custom_params", {})
        )
        return result
    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"Erreur simulation: {e}")
        raise HTTPException(status_code=500, detail=str(e))


@router.get("/export")
async def export_predictions(
    db: Session = Depends(get_db)
):
    """Exporte les prévisions au format CSV"""
    from fastapi.responses import StreamingResponse
    import io
    import csv
    
    try:
        data = predictive_service.get_dashboard_data(db)
        
        output = io.StringIO()
        writer = csv.writer(output)
        
        # En-têtes
        writer.writerow(["Date", "Prédiction (€)", "Borne Inf (€)", "Borne Sup (€)", "Confiance"])
        
        # Données
        for forecast in data["sales_forecast"]:
            writer.writerow([
                forecast["date"],
                forecast["predicted_value"],
                forecast["lower_bound"],
                forecast["upper_bound"],
                forecast["confidence"]
            ])
        
        output.seek(0)
        
        filename = f"predictions_b2b_{datetime.now().strftime('%Y%m%d_%H%M%S')}.csv"
        
        return StreamingResponse(
            io.BytesIO(output.getvalue().encode('utf-8-sig')),
            media_type="text/csv",
            headers={"Content-Disposition": f"attachment; filename={filename}"}
        )
    except Exception as e:
        logger.error(f"Erreur export: {e}")
        raise HTTPException(status_code=500, detail=str(e))


