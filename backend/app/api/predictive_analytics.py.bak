# app/api/predictive_analytics.py
from fastapi import APIRouter, Depends, HTTPException, Query
from typing import List, Dict, Any, Optional
from datetime import datetime
from sqlalchemy.orm import Session
import logging

from app.database import get_db
from app.services.predictiveAnalytic_service import predictive_service

router = APIRouter(prefix="/predictions", tags=["predictive-analytics"])
logger = logging.getLogger(__name__)

# Auth dépendance
async def get_current_user(token: Optional[str] = None):
    class CurrentUser:
        id = 1
        email = "admin@example.com"
    return CurrentUser()


@router.get("/dashboard")
async def get_dashboard(
    current_user = Depends(get_current_user),
    db: Session = Depends(get_db)
):
    """Récupère toutes les données du dashboard prédictif B2B"""
    try:
        data = predictive_service.get_dashboard_data(db)
        return {
            **data,
            "timestamp": datetime.now().isoformat()
        }
    except Exception as e:
        logger.error(f"Erreur dashboard: {e}")
        raise HTTPException(status_code=500, detail=str(e))


@router.get("/sales")
async def get_sales_forecast(
    period: str = Query("month", description="Période: week, month, quarter, year"),
    limit: int = Query(12, description="Nombre de périodes"),
    db: Session = Depends(get_db)
):
    """Récupère les prévisions de ventes B2B pour le futur"""
    try:
        # Calculer le nombre de périodes
        periods_map = {
            "week": limit,
            "month": limit,
            "quarter": limit * 3,
            "year": limit * 12
        }
        periods = periods_map.get(period, 12)
        
        # Générer les prévisions futures
        forecasts = predictive_service.generate_future_forecast(db, periods)
        
        # Filtrer pour n'avoir que les dates futures
        today = datetime.now().date()
        future_forecasts = [
            f for f in forecasts 
            if datetime.strptime(f["date"], "%Y-%m-%d").date() > today
        ]
        
        return future_forecasts
    except Exception as e:
        logger.error(f"Erreur sales forecast: {e}")
        raise HTTPException(status_code=500, detail=str(e))


